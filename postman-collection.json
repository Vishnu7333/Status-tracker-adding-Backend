  "item": [
    {
      "name": "1. Add Entry (Initial)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData.data) {",
              "    pm.collectionVariables.set(\"entryId\", jsonData.data.id);",
              "    pm.collectionVariables.set(\"userId\", jsonData.data.userId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-User-Email",
            "value": "john.doe@oracle.com",
            "type": "text"
          },
          {
            "key": "X-User-Name",
            "value": "John Doe",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"project\": \"Security Suite\",\n  \"module\": \"Login\",\n  \"submodule\": \"OAuth Flow\",\n  \"total\": 10,\n  \"pass\": 7,\n  \"fail\": 2,\n  \"onhold\": 0,\n  \"pending\": 1,\n  \"comments\": \"First test run of OAuth module\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/entries",
          "protocol": "http",
          "host": [
            "localhost"
          ],
